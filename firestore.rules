rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products collection - read access for everyone, write access for admin
    match /products/{productId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Orders collection - read/write access for everyone (manual collection)
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Allow all access for demo/development
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
